# Copia este archivo como .env y completa los valores

# Seguridad JWT (genera una clave segura: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=cambia_esto_por_una_clave_secreta_larga

# Email para envío de resúmenes (usa Gmail con App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_app_password_gmail

# Anthropic Claude API (para resúmenes inteligentes)
ANTHROPIC_API_KEY=sk-ant-...

# Base de datos
DATABASE_URL=sqlite:///./sunat_bot.db
